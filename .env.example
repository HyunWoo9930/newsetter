# 로컬 개발용 환경변수 예시.
# 복사해서 .env 로 만들고 값을 채우세요:  cp .env.example .env
# (.env 는 .gitignore 에 있어 커밋되지 않습니다. 실제 비밀값은 절대 커밋하지 마세요.)

# DB — 로컬은 embedded-postgres 기본값 (node scripts/devdb.mjs). docker 환경이면 compose 값 사용.
DATABASE_URL="postgresql://climbcrew:climbcrew@localhost:5432/climbcrew?schema=public"

# NextAuth — 운영에선 반드시 강력한 랜덤값으로 교체:  openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# 카카오 로그인 (https://developers.kakao.com) — REST API 키 / Client Secret
KAKAO_CLIENT_ID=""
KAKAO_CLIENT_SECRET=""

# 개발용 로그인 우회: 값이 있으면 세션 없이 이 유저로 API 호출됨. 운영에선 비워두세요.
DEV_USER_ID="devuser"

# 카카오 로그인 버튼 활성화 여부 ("true" 로 바꾸면 실제 카카오 로그인)
NEXT_PUBLIC_KAKAO_ENABLED="false"
# 카카오톡 공유(Share)용 JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY=""

# 네이버 지역검색 API (암장 데이터 수집용) — developers.naver.com > 검색 API (검수 불필요)
# node scripts/import-gyms-naver.mjs 로 서울·경기 암장 적재. (캐시가 있으면 --from-cache)
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# 네이버 지도 SDK (탐색 지도뷰) — console.ncloud.com > Maps > Application 의 Client ID
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=""
