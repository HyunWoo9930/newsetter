generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CrewRole {
  LEADER
  MEMBER
}

enum MemberStatus {
  PENDING
  APPROVED
}

enum JoinVia {
  INVITE_LINK
  REQUEST
}

enum VisitSource {
  VOTE
  MANUAL
}

enum PollStatus {
  OPEN
  CLOSED
}

// 그 색(난이도) 기준 체감
enum RelativeFeel {
  EASIER
  AS_EXPECTED
  HARDER
}

model User {
  id             String   @id @default(cuid())
  kakaoId        String?  @unique
  nickname       String
  profileImg     String?
  createdAt      DateTime @default(now())

  // 개인화 기준점
  homeGymId      String?
  referenceColor String?
  referenceGrade Int?

  memberships     CrewMember[]
  ledCrews        Crew[]             @relation("CrewLeader")
  createdPolls    Poll[]             @relation("PollCreator")
  dateVotes       PollDateVote[]
  gymVotes        PollGymVote[]
  reviews         Review[]
  reportedSets    GymSetting[]       @relation("SettingReporter")
  favorites       GymFavorite[]
  pushSubs        PushSubscription[]
  homeGym         Gym?               @relation("UserHomeGym", fields: [homeGymId], references: [id])
  climbLogs       ClimbLog[]
  colorGradeVotes ColorGradeVote[]
  createdProblems Problem[]          @relation("ProblemCreator")
  createdVisits   Visit[]            @relation("VisitCreator")
  visitAttendance VisitAttendee[]
  pollResponses   PollResponse[]
  events          ActivityEvent[]
  feedbacks       Feedback[]

  // 마지막 활동 시각(로그인·행동 시 갱신). 이탈(휴면) 판단용.
  lastSeenAt      DateTime?
  // "개발자에게 문의하기" 안내 모달을 본 시각 — 계정당 1회만 노출
  feedbackIntroSeenAt DateTime?
}

// 개발자에게 남기는 피드백 (기능 제안 · 버그 제보 · 의견)
model Feedback {
  id        String   @id @default(cuid())
  userId    String? // 탈퇴해도 피드백은 보존
  category  String // FEATURE | BUG | OTHER
  content   String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model Crew {
  id          String   @id @default(cuid())
  name        String
  description String?
  region      String?
  inviteCode  String   @unique
  openChatUrl String?
  leaderId    String
  createdAt   DateTime @default(now())

  leader   User          @relation("CrewLeader", fields: [leaderId], references: [id])
  members  CrewMember[]
  polls    Poll[]
  visits   Visit[]
  homeGyms CrewHomeGym[]
}

// 크루의 홈 암장 (자주 가는 곳). 크루 생성 시 몇 곳 지정.
model CrewHomeGym {
  id     String @id @default(cuid())
  crewId String
  gymId  String

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([crewId, gymId])
}

model CrewMember {
  id        String       @id @default(cuid())
  crewId    String
  userId    String
  role      CrewRole     @default(MEMBER)
  status    MemberStatus @default(APPROVED)
  joinedVia JoinVia      @default(INVITE_LINK)
  createdAt DateTime     @default(now())

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([crewId, userId])
  @@index([crewId, status])
}

model Gym {
  id              String   @id @default(cuid())
  name            String
  address         String?
  lat             Float?
  lng             Float?
  resetCycleWeeks Int      @default(4)
  gradeSystem     String?
  instagram       String?
  phone           String?
  kakaoPlaceId    String?  @unique
  createdAt       DateTime @default(now())

  settings        GymSetting[]
  visits          Visit[]
  reviews         Review[]
  favorites       GymFavorite[]
  pollGymOptions  PollGymOption[]
  colorGradeVotes ColorGradeVote[]
  homeUsers       User[]           @relation("UserHomeGym")
  crewHomeGyms    CrewHomeGym[]

  @@index([name])
}

// 세팅 회차(뉴셋). 유저 제보로 생성.
model GymSetting {
  id           String   @id @default(cuid())
  gymId        String
  setDate      DateTime
  noticeUrl    String?
  reportedById String?
  createdAt    DateTime @default(now())

  gym        Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  reportedBy User?     @relation("SettingReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  visits     Visit[]
  reviews    Review[]
  problems   Problem[]

  @@index([gymId, setDate])
}

model Visit {
  id           String      @id @default(cuid())
  crewId       String? // null = 개인 기록 (createdById 소유)
  gymId        String
  gymSettingId String?
  date         DateTime
  source       VisitSource @default(MANUAL)
  createdById  String?
  createdAt    DateTime    @default(now())

  crew       Crew?           @relation(fields: [crewId], references: [id], onDelete: Cascade)
  gym        Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  gymSetting GymSetting?     @relation(fields: [gymSettingId], references: [id])
  createdBy  User?           @relation("VisitCreator", fields: [createdById], references: [id], onDelete: SetNull)
  attendees  VisitAttendee[]

  @@index([crewId, gymId, date])
}

// 확정된 일정에 "간다"고 표시한 사람들 (참여하기)
model VisitAttendee {
  id        String   @id @default(cuid())
  visitId   String
  userId    String
  createdAt DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([visitId, userId])
  @@index([userId])
}

model Poll {
  id             String     @id @default(cuid())
  crewId         String
  creatorId      String
  title          String
  deadline       DateTime?
  status         PollStatus @default(OPEN)
  rangeStart     DateTime?
  rangeEnd       DateTime?
  confirmedDate  DateTime?
  confirmedGymId String?
  createdAt      DateTime   @default(now())

  crew        Crew             @relation(fields: [crewId], references: [id], onDelete: Cascade)
  creator     User             @relation("PollCreator", fields: [creatorId], references: [id])
  dateOptions PollDateOption[]
  gymOptions  PollGymOption[]
  dateVotes   PollDateVote[]
  gymVotes    PollGymVote[]
  responses   PollResponse[]

  @@index([crewId, status])
}

// 응답 여부(참여) 기록. "안 되는 날" 모델에선 X 0개(=다 가능)도 유효 응답이라
// 표 존재만으로 응답자를 세면 틀린다. 응답할 때 이 행을 upsert 해서 응답자 수를 센다.
model PollResponse {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  createdAt DateTime @default(now())

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId])
}

model PollDateOption {
  id     String   @id @default(cuid())
  pollId String
  date   DateTime
  label  String?

  poll  Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollDateVote[]
}

model PollGymOption {
  id     String @id @default(cuid())
  pollId String
  gymId  String

  poll  Poll          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  gym   Gym           @relation(fields: [gymId], references: [id])
  votes PollGymVote[]

  @@unique([pollId, gymId])
}

model PollDateVote {
  id           String @id @default(cuid())
  pollId       String
  userId       String
  dateOptionId String

  poll       Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOption PollDateOption @relation(fields: [dateOptionId], references: [id], onDelete: Cascade)

  @@unique([userId, dateOptionId])
  @@index([pollId])
}

model PollGymVote {
  id          String @id @default(cuid())
  pollId      String
  userId      String
  gymOptionId String

  poll      Poll          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymOption PollGymOption @relation(fields: [gymOptionId], references: [id], onDelete: Cascade)

  @@unique([userId, gymOptionId])
  @@index([pollId])
}

model Review {
  id           String   @id @default(cuid())
  userId       String
  gymId        String
  gymSettingId String?
  crewId       String?
  rating       Int
  tags         String[]
  content      String?
  createdAt    DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym        Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  gymSetting GymSetting? @relation(fields: [gymSettingId], references: [id])

  @@index([gymId, createdAt])
}

model GymFavorite {
  id     String @id @default(cuid())
  userId String
  gymId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── 문제 · 완등 로그 · 난이도 정규화 ──────────────────────────────

// 한 세팅 회차의 개별 문제 (색=난이도).
model Problem {
  id           String   @id @default(cuid())
  gymSettingId String
  color        String
  grade        Int?     // 명시적 등급이 있으면
  label        String?  // "빨강 3번" 등 식별용
  photoUrl     String?
  createdById  String?
  createdAt    DateTime @default(now())

  gymSetting GymSetting @relation(fields: [gymSettingId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation("ProblemCreator", fields: [createdById], references: [id], onDelete: SetNull)
  logs       ClimbLog[]

  @@index([gymSettingId, color])
}

// 완등 로그 + 베타 + 난이도 신호 + 영상(선택). 유저당 문제당 1개(수정 가능).
model ClimbLog {
  id           String        @id @default(cuid())
  problemId    String
  userId       String
  sent         Boolean       @default(false)
  attempts     Int?
  relativeFeel RelativeFeel?
  honey        Boolean       @default(false)
  content      String?
  videoUrl     String?
  videoThumb   String?
  createdAt    DateTime      @default(now())

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([problemId, userId])
  @@index([problemId])
  @@index([userId])
}

// 암장의 색 → 공통 척도(V등급) 추정 투표. 세트를 넘어 영구 누적.
model ColorGradeVote {
  id        String   @id @default(cuid())
  gymId     String
  color     String
  userId    String
  vGrade    Int
  createdAt DateTime @default(now())

  gym  Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gymId, color, userId])
  @@index([gymId, color])
}

// 사용자 행동 로그. 누가 언제 무엇을 했는지 남겨 이탈 퍼널·활동 분석에 사용.
// userId 는 nullable + SetNull → 탈퇴 후에도 이탈/분석 데이터를 보존.
model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String?
  type      String // login, signup, crew_create, poll_vote, visit_join ... (lib/activity.ts EventType)
  meta      Json? // { crewId, pollId, gymId, name ... }
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}
